# Copy to .env.local for Supabase-backed auth and data (optional — app runs in demo mode without these)
# Local stack: run `npm run supabase:start` then `npm run supabase:status` (see docs/SUPABASE_LOCAL_DEV.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (local dev). Never set NEXT_PUBLIC_* or commit production service keys.
SUPABASE_SERVICE_ROLE_KEY=
# Set to "true" to require login for all routes (needs valid Supabase Auth).
# Also auto-enabled when Supabase URL + dual_write/server_authoritative (planning sync RLS).
NEXT_PUBLIC_REQUIRE_AUTH=
# Legacy: allow dev tenant without session while dual_write (skips login redirect; sync will 401)
# NEXT_PUBLIC_ALLOW_DEV_TENANT_WITHOUT_AUTH=true

# Phase 2 persistence (client)
# local_only = namespaced local + optional GET hydrate only
# dual_write = local + debounced PUT /api/org/hr-catalog (Phase 2.2)
# server_authoritative = server-only writes (Phase 2.6)
NEXT_PUBLIC_PERSIST_MODE=local_only
# When Supabase URL is set, planning workspace hydrates from server (default on). Set false to skip.
# NEXT_PUBLIC_WORKSPACE_SERVER_HYDRATE=false
# Phase 2.1: GET /api/org/hr-catalog on load (set false to skip server read)
NEXT_PUBLIC_HR_SERVER_HYDRATE=true
# Set to "false" to use legacy global localStorage keys only
NEXT_PUBLIC_TENANT_NAMESPACED_PERSIST=true
# Dev fallback when /api/tenant/context returns 401 (development only)
NEXT_PUBLIC_DEV_TENANT_ID=
NEXT_PUBLIC_DEV_TENANT_NAME=
# Server-side dev bypass (must match NEXT_PUBLIC_DEV_TENANT_ID for consistent namespacing)
DEV_TENANT_ID=
DEV_TENANT_NAME=

# Incentives: allow in-memory persistence when Supabase is not configured (local dev only).
# Do NOT enable in pilot/staging — use Supabase + migration 013 instead.
# INCENTIVE_ALLOW_MEMORY_FALLBACK=true
# Show sample-data panels after linked units exist (dev/pilot demos)
# NEXT_PUBLIC_ENABLE_SAMPLE_DATA=true
# QA panel + persistence banner (dev or staging pilot)
# NEXT_PUBLIC_SHOW_QA_PANEL=true
# Legacy alias — banner uses same gate as QA panel
# NEXT_PUBLIC_SHOW_PERSISTENCE_BANNER=true
